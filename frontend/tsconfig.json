
{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    },
    "module": "commonjs",           
    "target": "es6",                
    "strict": true,                
    "esModuleInterop": true,       
    "skipLibCheck": true,            
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",               
    "allowSyntheticDefaultImports": true, 
    "resolveJsonModule": true        
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}